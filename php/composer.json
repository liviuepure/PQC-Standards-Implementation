{
    "name": "pqc/standards",
    "description": "Pure PHP implementation of NIST PQC standards",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-gmp": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "PQC\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PQC\\Tests\\": "tests/"
        }
    }
}
